@model divelog.ViewModels.EditSurfaceSupportDiveViewModel

@{
    ViewData["Title"] = "Redigera dyk (luft från ytan)";
}

<h2 class="h2-tab">Redigera dyk (luft från ytan)</h2>

<form asp-action="EditSurfaceSupportDive" method="post" class="dive-form">

    <!-- Dykets ID används för att rätt dyk ska uppdateras -->
    <input type="hidden" asp-for="DiveId" />

    <!-- Valideringsfel visas här -->
    <div asp-validation-summary="All" class="error"></div>

    <!-- GEMENSAM DYKINFORMATION -->
    <div class="form-row">
        <label asp-for="Date">Datum:</label>
        <input asp-for="Date" type="date" class="date-input" />
    </div>

    <div class="form-row">
        <label asp-for="StartTime">Starttid:</label>
        <input asp-for="StartTime" type="time" />
    </div>

    <div class="form-row">
        <label asp-for="LocationName">Plats:</label>
        <input asp-for="LocationName" />
    </div>

    <div class="form-row">
        <label asp-for="DivePurposeId">Typ av dyk:</label>
        <select asp-for="DivePurposeId">
            @foreach (var purpose in Model.DivePurposes)
            {
                <option value="@purpose.Id">
                    @purpose.Name
                </option>
            }
        </select>
    </div>

    <div class="form-row">
        <label asp-for="DiveLeaderId">Dykledare:</label>
        <select asp-for="DiveLeaderId">
            @foreach (var p in Model.DiveLeaders)
            {
                <option value="@p.Id">
                    @p.Signature @p.Name
                </option>
            }
        </select>
    </div>

    <!-- DYKARE + DYKSKÖTARE -->
    <h4>Dykare + Dykskötare</h4>

    <div class="surface-support-card">

        <div class="form-row">
            <label asp-for="DiverId">Dykare:</label>
            <select asp-for="DiverId">
                @foreach (var p in Model.AvailableDivers)
                {
                    <option value="@p.Id">
                        @p.Signature @p.Name
                    </option>
                }
            </select>
        </div>

        <div class="form-row">
            <label asp-for="SurfaceSupportId">Dykskötare:</label>
            <select asp-for="SurfaceSupportId">
                @foreach (var p in Model.SurfaceSupports)
                {
                    <option value="@p.Id">
                        @p.Signature @p.Name
                    </option>
                }
            </select>
        </div>

        <div class="form-row">
            <label asp-for="AirPressureBefore">Lufttryck före:</label>
            <input asp-for="AirPressureBefore" />
        </div>

        <div class="form-row">
            <label asp-for="AirPressureAfter">Lufttryck efter:</label>
            <input asp-for="AirPressureAfter" />
        </div>

        <div class="form-row">
            <label asp-for="Depth">Djup:</label>
            <input asp-for="Depth" class="depth-input" />
        </div>

        <div class="form-row">
            <label asp-for="DiveTime">Dyktid:</label>
            <input asp-for="DiveTime" class="time-input" />
        </div>

        <div class="form-row">
            <label>Expositionstid:</label>
            <p class="exposition-time">0 min</p>
        </div>

    </div>

    <div class="notes">
        <label asp-for="Notes">Anteckningar:</label>
        <textarea asp-for="Notes"></textarea>
    </div>

    <input asp-for="Latitude" id="Latitude" type="hidden" />
    <input asp-for="Longitude" id="Longitude" type="hidden" />
    <div id="map"></div>

    <!-- SPARA -->
    <button type="submit" class="form-btn">
        Spara ändringar
    </button>

</form>

<div class="navigate-back">
    <a asp-action="Index">Tillbaka till Dyklogg</a>
</div>

<script>
    function calculateExposure(depth, time) {
        if (!depth || !time) return 0;

        const depthFactor = Math.ceil(depth / 9);
        return Math.max(0, time - depthFactor);
    }

    //Uppdaterar expositionstiden i rätt kort
    function updateExposure() {
        const depthInput = document.querySelector(".depth-input");
        const timeInput = document.querySelector(".time-input");
        const output = document.querySelector(".exposition-time");

        if (!depthInput || !timeInput || !output) return;

        const depth = parseFloat(depthInput.value);
        const time = parseFloat(timeInput.value);

        const exposure = calculateExposure(depth, time);

        output.textContent = exposure + " min";
    }

    //Lyssnar när användaren skriver i djup eller dyktid
    document.addEventListener("input", function (e) {
        if (
            e.target.classList.contains("depth-input") ||
            e.target.classList.contains("time-input")
        ) {
            updateExposure();
        }
    });

    window.onload = function () {
        updateExposure();
    };
</script>

@section Scripts {
    <script>

        //Hämta sparade koordinater
        var lat = @Model.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var lng = @Model.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

        // Skapa karta
        var map = L.map('map').setView([lat, lng], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        var marker = L.marker([lat, lng]).addTo(map);

        // Flytta markering vid klick
        map.on('click', function (e) {

            var newLat = e.latlng.lat.toFixed(6);
            var newLng = e.latlng.lng.toFixed(6);

            marker.setLatLng([newLat, newLng]);

            // Byter ut punkt mot decimal för korrekt format
            document.getElementById("Latitude").value =
                newLat.replace('.', ',');

            document.getElementById("Longitude").value =
                newLng.replace('.', ',');
        });

    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}