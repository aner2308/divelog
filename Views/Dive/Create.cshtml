@model divelog.ViewModels.CreateDiveViewModel

@{
    ViewData["Title"] = "Registrera dyk";
}

<h2>Registrera dyk</h2>

<!-- FLIKAR -->
<div class="tabs-btn">
    <button type="button" onclick="showSurfaceSupport(this)">Dykare + Dykskötare</button>
    <button type="button" onclick="showBuddyDive(this)">Pardyk</button>
</div>

<form asp-action="Create" method="post" class="dive-form">

    <div asp-validation-summary="All" class="error"></div>

    <!-- GEMENSAM INFO -->
    <div class="form-row">
        <label asp-for="Date">Datum: </label>
        <input asp-for="Date" type="date" class="date-input" />
    </div>

    <div class="form-row">
        <label asp-for="StartTime">Starttid: </label>
        <input asp-for="StartTime" type="time" />
    </div>

    <div class="form-row">
        <label asp-for="LocationName">Plats: </label>
        <input asp-for="LocationName" />
    </div>

    <div class="form-row">
        <label asp-for="DivePurposeId">Typ av dyk: </label>
        <select asp-for="DivePurposeId">

            @foreach (var purpose in Model.DivePurposes)
            {
                <option value="@purpose.Id">@purpose.Name</option>
            }
        </select>
    </div>

    <div class="form-row">
        <label asp-for="DiveLeaderId">Dykledare: </label>
        <select asp-for="DiveLeaderId">
            <option value="">Välj dykledare</option>
            @foreach (var person in Model.DiveLeaders)
            {
                <option value="@person.Id">@person.Signature @person.Name</option>
            }
        </select>
    </div>

    <input type="hidden" asp-for="DiveType" id="DiveType" />

    <!-- PARDYK -->
    <div id="buddyDiveSection" style="display:none;">

        <h4>Pardyk</h4>

        <div id="pairGroupsContainer">

            @for (int pairIndex = 0; pairIndex < Model.PairGroups.Count; pairIndex++)
            {
                <div class="pair-group" id="pairGroup-@pairIndex">

                    <h5>Dykpar @(pairIndex + 1)</h5>

                    <div class="diversContainer">
                        
                        @for (int diverIndex = 0; diverIndex < Model.PairGroups[pairIndex].Divers.Count; diverIndex++)
                        {
                            <div class="diver-card">

                                
                                <select asp-for="PairGroups[@pairIndex].Divers[@diverIndex].DiverId">
                                    <option value="">Välj dykare</option>
                                    @foreach (var person in Model.Divers)
                                    {
                                        <option value="@person.Id">@person.Signature @person.Name</option>
                                    }
                                </select>

                                <label>Lufttryck före: </label>
                                <input asp-for="PairGroups[@pairIndex].Divers[@diverIndex].AirPressureBefore" />

                                <label>Djup: </label>
                                <input asp-for="PairGroups[@pairIndex].Divers[@diverIndex].Depth" class="depth-input"/>

                                <label>Dyktid: </label>
                                <input asp-for="PairGroups[@pairIndex].Divers[@diverIndex].DiveTime" class="time-input"/>

                                <label>Lufttryck efter: </label>
                                <input asp-for="PairGroups[@pairIndex].Divers[@diverIndex].AirPressureAfter" />

                
                                <label>Expositionstid: </label>
                                <p class="exposition-time">0 min</p>
                                

                            </div>
                        }

                    </div>

                    <button type="button" class="form-btn" onclick="addDiverToPair(@pairIndex)" id="addThirdDiver-@pairIndex">
                        + Lägg till tredje dykare
                    </button>

                    <button type="button" class="form-btn remove-btn" onclick="removeThirdDiver(@pairIndex)" id="removeThirdDiver-@pairIndex"
                            style="display:none;">
                        Ta bort tredje dykare
                    </button>

                    @if (pairIndex > 0)
                    {
                        <button type="button" class="form-btn remove-btn" onclick="removePairGroup(@pairIndex)">
                            Ta bort dykpar
                        </button>
                    }

                </div>
            }

        </div>

        <button type="button" class="form-btn" onclick="addPairGroup()">
            + Lägg till nytt dykpar
        </button>

    </div>


    <!-- LUFT FRÅN YTAN -->
    <div id="surfaceSupportSection">

        <h4>Dykare + Dykskötare</h4>

        <div id="groupsContainer">

            @for (int i = 0; i < Model.SurfaceSupportGroups.Count; i++)
            {
                <div class="surface-support-card" id="group-@i">
                    <div class="form-row">
                        <label>Dykare: </label>
                        <select asp-for="SurfaceSupportGroups[@i].DiverId">
                            <option value="">Välj dykare</option>
                            @foreach (var person in Model.Divers)
                            {
                                <option value="@person.Id">@person.Signature @person.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-row">
                        <label>Dykskötare: </label>
                        <select asp-for="SurfaceSupportGroups[@i].SurfaceSupportId">
                            <option value="">Välj dykskötare</option>
                            @foreach (var person in Model.SurfaceSupports)
                            {
                                <option value="@person.Id">@person.Signature @person.Name</option>
                            }
                        </select>
                    </div>

                    <div class="form-row">
                        <label>Lufttryck före: </label>
                        <input asp-for="SurfaceSupportGroups[@i].AirPressureBefore" />
                    </div>

                    <div class="form-row">
                        <label>Lufttryck efter: </label>
                        <input asp-for="SurfaceSupportGroups[@i].AirPressureAfter" />
                    </div>

                    <div class="form-row">
                        <label>Djup: </label>
                        <input asp-for="SurfaceSupportGroups[@i].Depth" class="depth-input"/>
                    </div>

                    <div class="form-row">
                        <label>Dyktid: </label>
                        <input asp-for="SurfaceSupportGroups[@i].DiveTime" class="time-input"/>
                    </div>

                    <div class="form-row">
                        <label>Expositionstid: </label>
                        <p class="exposition-time">0 min</p>
                    </div>

                    @if (i > 0)
                    {
                        <button type="button" class="form-btn remove-btn" onclick="removeGroup(@i)">
                            Ta bort grupp
                        </button>
                    }

                </div>
            }

        </div>

        <button type="button" class="form-btn" onclick="addGroup()">
            + Lägg till dykare + dykskötare
        </button>

    </div>

    <div class="notes">
        <label asp-for="Notes">Anteckningar: </label>
        <textarea asp-for="Notes"></textarea>
    </div>

    <div id="map"></div>
    <input asp-for="Latitude" id="Latitude" type="hidden" />
    <input asp-for="Longitude" id="Longitude" type="hidden" />

    <br />

    <button type="submit" class="form-btn">
        Spara
    </button>

</form>

<div class="navigate-back">
    <a asp-action="Index">Tillbaka till Dyklogg</a>
</div>

<script>

    let groupIndex = @Model.SurfaceSupportGroups.Count;
    let pairIndex = @Model.PairGroups.Count;

    function setSectionEnabled(sectionId, enabled) {

        let inputs = document.querySelectorAll(`#${sectionId} input, #${sectionId} select, #${sectionId} textarea`);

        inputs.forEach(input => {
            input.disabled = !enabled;
        });
    }

    //Lägger till/tar bort klassen "active" på vald flik
    function setActiveTab(activeButton) {
        document.querySelectorAll(".tabs-btn button").forEach(btn => {
            btn.classList.remove("active");
        });

        activeButton.classList.add("active");
    }

    function showBuddyDive(button) {

        //Gör den valda fliken aktiv 
        setActiveTab(button);

        document.getElementById("buddyDiveSection").style.display = "block";
        document.getElementById("surfaceSupportSection").style.display = "none";

        setSectionEnabled("buddyDiveSection", true);
        setSectionEnabled("surfaceSupportSection", false);

        document.getElementById("DiveType").value = "1";
    }

    function showSurfaceSupport(button) {

        //Gör den valda fliken aktiv
        setActiveTab(button);

        document.getElementById("buddyDiveSection").style.display = "none";
        document.getElementById("surfaceSupportSection").style.display = "block";

        setSectionEnabled("buddyDiveSection", false);
        setSectionEnabled("surfaceSupportSection", true);

        document.getElementById("DiveType").value = "2";
    }

    function addGroup() {

        if (document.querySelectorAll(".surface-support-card").length >= 4) return;

        //Skapar nytt div-element
        let newGroup = document.createElement("div");

        //Fyller nya elementet
        newGroup.innerHTML = `
        <div class="surface-support-card" id="group-${groupIndex}">
            
            <div class="form-row">
                <label>Dykare: </label>
                <select name="SurfaceSupportGroups[${groupIndex}].DiverId">
                    <option value="">Välj dykare</option>
                    @foreach (var person in Model.Divers)
                    {
                        <option value="@person.Id">@person.Signature @person.Name</option>
                    }
                </select>
            </div>
            
            <div class="form-row">
                <label>Dykskötare: </label>
                <select name="SurfaceSupportGroups[${groupIndex}].SurfaceSupportId">
                    <option value="">Välj dykskötare</option>
                    @foreach (var person in Model.SurfaceSupports)
                    {
                        <option value="@person.Id">@person.Signature @person.Name</option>
                    }
                </select>
            </div>

            <div class="form-row">
                <label>Lufttryck före: </label>
                <input name="SurfaceSupportGroups[${groupIndex}].AirPressureBefore"/>
            </div>

            <div class="form-row">
                <label>Lufttryck efter: </label>
                <input name="SurfaceSupportGroups[${groupIndex}].AirPressureAfter"/>
            </div>

            <div class="form-row">
                <label>Djup: </label>
                <input name="SurfaceSupportGroups[${groupIndex}].Depth" class="depth-input"/>
            </div>

            <div class="form-row">    
                <label>Dyktid: </label>
                <input name="SurfaceSupportGroups[${groupIndex}].DiveTime" class="time-input"/>
            </div>

            <div class="form-row">
                <label>Expositionstid: </label>
                <p class="exposition-time">0 min</p>
            </div>
            <button type="button" class="form-btn remove-btn" onclick="removeGroup(${groupIndex})">Ta bort grupp</button>

        </div>
    `;

        //Lägger in skapad div som child-element
        groupsContainer.appendChild(newGroup.firstElementChild);
        //Ökar index
        groupIndex++;
    }

    function removeGroup(index) {
        document.getElementById(`group-${index}`).remove();
    }

    function addPairGroup() {

        //Skapar nytt div-element
        let newGroup = document.createElement("div");

        //Fyller nya elementet
        newGroup.innerHTML = `
        <div class="pair-group" id="pairGroup-${pairIndex}">

            <h5>Dykpar ${pairIndex + 1}</h5>

            <div class="diversContainer">
                ${generateDiverHtml(pairIndex, 0)}
                ${generateDiverHtml(pairIndex, 1)}
            </div>

            <button type="button" class="form-btn" onclick="addDiverToPair(${pairIndex})" id="addThirdDiver-${pairIndex}">
                + Lägg till tredje dykare
            </button>

            <button type="button" class="form-btn remove-btn" onclick="removeThirdDiver(${pairIndex})" id="removeThirdDiver-${pairIndex}" style="display:none;">
                Ta bort tredje dykare
            </button>

            <button type="button" class="form-btn remove-btn" onclick="removePairGroup(${pairIndex})">
                Ta bort dykpar
            </button>

        </div>
    `;
        //Lägger in skapad div som child-element
        pairGroupsContainer.appendChild(newGroup.firstElementChild);
        //Ökar index
        pairIndex++;
    }

    function generateDiverHtml(pairGroupIndex, diverIndex) {

        return `
        <div class="diver-card">

            <select name="PairGroups[${pairGroupIndex}].Divers[${diverIndex}].DiverId">
                <option value="">Välj dykare</option>
                @foreach (var person in Model.Divers)
                {
                    <option value="@person.Id">@person.Signature @person.Name</option>
                }
            </select>
            
            <label>Lufttryck före: </label>
            <input name="PairGroups[${pairGroupIndex}].Divers[${diverIndex}].AirPressureBefore"/>

            <label>Djup: </label>
            <input name="PairGroups[${pairGroupIndex}].Divers[${diverIndex}].Depth" class="depth-input"/>

            <label>Dyktid: </label>
            <input name="PairGroups[${pairGroupIndex}].Divers[${diverIndex}].DiveTime" class="time-input"/>

            <label>Lufttryck efter: </label>
            <input name="PairGroups[${pairGroupIndex}].Divers[${diverIndex}].AirPressureAfter"/>

            <label>Expositionstid: </label>
            <p class="exposition-time">0 min</p>

        </div>
    `;
    }

    function addDiverToPair(pairGroupIndex) {

        let container = document.querySelector(`#pairGroup-${pairGroupIndex} .diversContainer`);

        let diverCount = container.children.length;

        if (diverCount >= 3) return;

        container.innerHTML += generateDiverHtml(pairGroupIndex, diverCount);

        document.getElementById(`addThirdDiver-${pairGroupIndex}`).style.display = "none";
        document.getElementById(`removeThirdDiver-${pairGroupIndex}`).style.display = "inline-block";
    }

    function removeThirdDiver(pairGroupIndex) {

        let container = document.querySelector(`#pairGroup-${pairGroupIndex} .diversContainer`);

        container.removeChild(container.lastElementChild);

        document.getElementById(`addThirdDiver-${pairGroupIndex}`).style.display = "inline-block";
        document.getElementById(`removeThirdDiver-${pairGroupIndex}`).style.display = "none";
    }

    function removePairGroup(index) {
        document.getElementById(`pairGroup-${index}`).remove();
    }

    //Räkna ut expositionstid utifrån djup och tid
    function calculateExposure(depth, time) {
        if (!depth || !time) return 0;

        const depthFactor = Math.ceil(depth / 9);
        return Math.max(0, time - depthFactor);
    }

    //Uppdatera expositionstid
    function updateExposureFromCard(card) {
        const depthInput = card.querySelector(".depth-input");
        const timeInput = card.querySelector(".time-input");
        const output = card.querySelector(".exposition-time");

        if (!depthInput || !timeInput || !output) return;

        const depth = parseFloat(depthInput.value);
        const time = parseFloat(timeInput.value);

        const exposure = calculateExposure(depth, time);

        output.textContent = exposure + " min";
    }

    //Vid sidinladdning
    window.onload = function () {

        const diveType = document.getElementById("DiveType").value;
        const buttons = document.querySelectorAll(".tabs-btn button");

        //Om användaren redan har valt pardyk så uppdateras sidan på den fliken
        if (diveType === "1") {
            showBuddyDive(buttons[1]);
        } else {

            //Annars uppdareras sidan på fliken "Luft från ytan" som standard
            showSurfaceSupport(buttons[0]);
        }

        document.addEventListener("input", function (e) {
            if (e.target.classList.contains("depth-input") ||
                e.target.classList.contains("time-input")) {

                // hitta rätt kort (funkar för båda typer)
                const card = e.target.closest(".surface-support-card") 
                        || e.target.closest(".diver-card");

                if (card) {
                    updateExposureFromCard(card);
                }
            }
        });
    };
</script>

@section Scripts {
    <script>

        // Skapar kartan
        var map = L.map('map');

        // OpenStreetMap tiles
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        var marker;

        // Om användaren har platstjänster aktiverade
        if (navigator.geolocation) {
            navigator.geolocation.getCurrentPosition(function (position) {

                var userLat = position.coords.latitude;
                var userLng = position.coords.longitude;

                // Zooma till användarens position
                map.setView([userLat, userLng], 15);

            }, function () {
                //Om man inte har platstjänst aktiverad visas Västerås som default
                map.setView([59.595, 16.56], 13);   
            });
        } else {
            map.setView([59.595, 16.56], 13);
        }

        // När användaren klickar på kartan
        map.on('click', function (e) {

            // Riktiga nummer för Leaflet
            var lat = e.latlng.lat;
            var lng = e.latlng.lng;

            // Formatterade värden för ASP.NET
            var latForInput = lat.toFixed(6).replace('.', ',');
            var lngForInput = lng.toFixed(6).replace('.', ',');

            // Ta bort gammal marker
            if (marker) {
                map.removeLayer(marker);
            }

            // Lägg till ny marker (MÅSTE vara riktiga nummer)
            marker = L.marker([lat, lng]).addTo(map);

            // Spara till hidden inputs (med komma)
            document.getElementById("Latitude").value = latForInput;
            document.getElementById("Longitude").value = lngForInput;
        });

    </script>

    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}

