@model IEnumerable<divelog.Models.Dive>

@{
    ViewData["Title"] = "Index";
    Layout = "_LayoutPattern";

    //Variabler för paginering
    int currentPage = ViewBag.CurrentPage;
    int totalPages = ViewBag.TotalPages;
    int maxPagesToShow = 5;

    int startPage = Math.Max(1, currentPage - 2);
    int endPage = Math.Min(totalPages, startPage + maxPagesToShow - 1);

    //Justera vilka sidor som visas på slutet
    if (endPage - startPage < maxPagesToShow - 1)
    {
        startPage = Math.Max(1, endPage - maxPagesToShow + 1);
    }
}

<h1>Dyklogg</h1>

<div class="page-container">
    <div class="table-tools">
        <form method="get" class="dive-filter-form">
            <select name="groupId" asp-items="ViewBag.Groups" onchange="this.form.submit()">
                <option value="">Alla grupper</option>
            </select>
            <select name="personId" asp-items="ViewBag.Persons" onchange="this.form.submit()">
                <option value="">Alla personer</option>
            </select>
            <select name="divePurposeId" asp-items="ViewBag.Purposes" onchange="this.form.submit()">
                <option value="">Alla syften</option>
            </select>
        </form>
        <a asp-action="Create" class="table-btn add-btn">Nytt dyk</a>
    </div>

    <div class="table-container">
        <table class="dive-table">
            <thead>
                <tr>
                    <th>Datum</th>
                    <th>Plats</th>
                    <th>Dykledare</th>
                    <th>Dykare</th>
                    <th>Dykskötare</th>
                    <th>Syfte</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>

                @foreach (var dive in Model)
                {
                    var diveLeader = dive.DiveParticipants?
                        .FirstOrDefault(p => p.DiveRoleId == 2)?.Person;

                    var divers = dive.DiveParticipants?
                        .Where(p => p.DiveRoleId == 1)
                        .Select(p => p.Person)
                        .ToList();

                    var diveSupport = dive.DiveParticipants?
                        .FirstOrDefault(p => p.DiveRoleId == 3)?.Person;

                    <tr>
                        <td>
                            @dive.Date.ToString("yyyy-MM-dd")
                        </td>

                        <td>
                            @dive.LocationName
                        </td>

                        <td>
                            @if (diveLeader != null)
                            {
                                @($"{diveLeader.Signature} - ")
                                @($"{diveLeader.Name}")
                            }
                        </td>

                        <td>
                            @if (divers != null)
                            {
                                foreach (var d in divers)
                                {
                                    <div>@($"{d.Signature} - ")@($"{d.Name}")</div>
                                }
                            }
                        </td>

                        <td>
                            @if (diveSupport != null)
                            {
                                @($"{diveSupport.Signature} - ")
                                @($"{diveSupport.Name}")
                            }
                        </td>

                        <td>
                            @dive.DivePurpose?.Name
                        </td>

                        <td>
                            <div class="button-wrapper">
                                <a asp-action="Edit" asp-route-id="@dive.Id" class="table-btn">Redigera</a>
                                <a asp-action="Details" asp-route-id="@dive.Id" class="table-btn">Detaljer</a>
                                <a asp-action="Delete" asp-route-id="@dive.Id" class="table-btn">Radera</a>
                            </div>
                        </td>
                    </tr>
                }

            </tbody>
        </table>
    </div>
    @if (ViewBag.TotalPages > 1)
    {
        <div class="pagination">
            @if (currentPage > 1)
            {
                <a asp-action="Index" asp-route-page="1" asp-route-groupId="@ViewBag.GroupId"
                   asp-route-personId="@ViewBag.PersonId" asp-route-divePurposeId="@ViewBag.DivePurposeId">«</a>
                <a asp-action="Index" asp-route-page="@(currentPage - 1)" asp-route-groupId="@ViewBag.GroupId"
                   asp-route-personId="@ViewBag.PersonId" asp-route-divePurposeId="@ViewBag.DivePurposeId">‹</a>
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <a asp-action="Index" asp-route-page="@i" asp-route-groupId="@ViewBag.GroupId"
                   asp-route-personId="@ViewBag.PersonId" asp-route-divePurposeId="@ViewBag.DivePurposeId"
                   class="@(currentPage == i ? "active-page" : "")">@i</a>
            }

            @if (currentPage < totalPages)
            {
                <a asp-action="Index" asp-route-page="@(currentPage + 1)" asp-route-groupId="@ViewBag.GroupId"
                   asp-route-personId="@ViewBag.PersonId" asp-route-divePurposeId="@ViewBag.DivePurposeId">›</a>
                <a asp-action="Index" asp-route-page="@totalPages" asp-route-groupId="@ViewBag.GroupId"
                   asp-route-personId="@ViewBag.PersonId" asp-route-divePurposeId="@ViewBag.DivePurposeId">»</a>
            }
        </div>
    }
</div>

<div class="map-padding">
    <div id="big-map"></div>
</div>

@section Scripts {

    <script>

    var dives = [
         @foreach (var dive in Model) {
            if (dive.Latitude >= -90 && dive.Latitude <= 90 && dive.Longitude >= -180 && dive.Longitude <= 180) 
            {
                <text> {
                    id: @dive.Id,
                    lat: @dive.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    lng: @dive.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture),
                    location: "@dive.LocationName",
                    date: "@dive.Date.ToString("yyyy-MM-dd")",
                    },
                </text>
            }
        }
    ];

    var map = L.map('big-map');

    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap'
    }).addTo(map);

    var markers = [];

    //Lägger till popup med plats, datum och länk till dyk.
    dives.forEach(function(dive) {

        var marker = L.marker([dive.lat, dive.lng])
            .addTo(map)
            .bindPopup(`
                <strong>${dive.location}</strong><br>
                ${dive.date}<br>
                <a href="/Dive/Details/${dive.id}">Visa dyk</a>
            `);

        markers.push(marker);
    });

    // Auto-zoom till alla markeringar
    if (markers.length > 0) {
        var group = L.featureGroup(markers);
        map.fitBounds(group.getBounds().pad(0.2));
    } else {
        map.setView([59.595, 16.56], 13);
    }

    </script>
}