@model divelog.Models.Dive

<h2>Dykdetaljer</h2>

<hr />

<h4>Grundinformation</h4>
<h5>
    @if (Model.DiveType == divelog.Models.DiveType.Pardyk)
    {
        <span>Pardyk</span>
    }
    else
    {
        <span>Luft från ytan</span>
    }
</h5>

<dl class="row">
    <dt class="col-sm-3">Datum</dt>
    <dd class="col-sm-9">@Model.Date.ToString("yyyy-MM-dd")</dd>

    <dt class="col-sm-3">Starttid</dt>
    <dd class="col-sm-9">@Model.StartTime.ToString(@"hh\:mm")</dd>

    <dt class="col-sm-3">Plats</dt>
    <dd class="col-sm-9">@Model.LocationName</dd>

    <dt class="col-sm-3">Koordinater</dt>
    <dd class="col-sm-9">
        @Model.Latitude , @Model.Longitude
    </dd>

    <dt class="col-sm-3">Syfte</dt>
    <dd class="col-sm-9">@Model.DivePurpose?.Name</dd>

    <dt class="col-sm-3">Anteckningar</dt>
    <dd class="col-sm-9">@Model.Notes</dd>
</dl>

<hr />

<h4>Deltagare</h4>

@{
    var leader = Model.DiveParticipants?
        .FirstOrDefault(p => p.DiveRoleId == 2);

    var divers = Model.DiveParticipants?
        .Where(p => p.DiveRoleId == 1)
        .ToList();

    var support = Model.DiveParticipants?
        .FirstOrDefault(p => p.DiveRoleId == 3);
}

<!-- Dykledare -->
@if (leader != null)
{
    <p><strong>Dykledare:</strong> @leader.Person.Signature @leader.Person.Name</p>
}

<!-- Dykskötare -->
@if (support != null)
{
    <p><strong>Dykskötare:</strong> @support.Person.Signature @support.Person.Name</p>
}

<hr />

<h4>Dykare</h4>

<table class="table">
    <thead>
        <tr>
            <th>Namn</th>
            <th>Djup</th>
            <th>Dyktid</th>
            <th>Expositionstid</th>
            <th>Kvävebelastning</th>
            <th>Luft (före/efter)</th>
        </tr>
    </thead>
    <tbody>

        @foreach (var d in divers ?? new List<divelog.Models.DiveParticipant>())
        {
            <tr>
                <td>@d.Person.Signature @d.Person.Name</td>

                <td>@(d.Depth?.ToString()) m</td>

                <td>@(d.DiveTime?.ToString()) min</td>

                <td>@(d.ExposureTime?.ToString()) min</td>

                <td>@(d.NitrogenLoad?.ToString())</td>

                <td>
                    @if (d.AirPressureBefore.HasValue && d.AirPressureAfter.HasValue)
                    {
                        @($"{d.AirPressureBefore} / {d.AirPressureAfter} bar")
                    }
                    else
                    {
                        <span>-</span>
                    }
                </td>
            </tr>
        }

    </tbody>
</table>

<hr />

<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Redigera</a>

    <a asp-action="Delete" asp-route-id="@Model.Id" class="btn btn-danger">Ta bort</a>

    <a asp-action="Index" class="btn btn-secondary">Tillbaka</a>
</div>