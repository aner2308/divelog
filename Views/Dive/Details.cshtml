@model divelog.Models.Dive

@{
    ViewData["Title"] = "Dykdetaljer";
}

<h2>Dykdetaljer</h2>

@{
    var leader = Model.DiveParticipants?
        .FirstOrDefault(p => p.DiveRoleId == 2);

    var divers = Model.DiveParticipants?
        .Where(p => p.DiveRoleId == 1)
        .ToList();

    var support = Model.DiveParticipants?
        .FirstOrDefault(p => p.DiveRoleId == 3);
}

<div class="dive-form dive-details">

    <!-- Titelrad -->
    <h3 class="dive-title">
        @Model.Date.ToString("yyyy-MM-dd")
        – @Model.LocationName
    </h3>

    <div class="details-layout">

        <!-- Vänster kolumn -->
        <dl class="details-list">

            <dt>Dyktyp:</dt>
            <dd>
                @if (Model.DiveType == divelog.Models.DiveType.Pardyk)
                {
                    <span>Pardyk</span>
                }
                else
                {
                    <span>Luft från ytan</span>
                }
            </dd>

            <dt>Starttid:</dt>
            <dd>@Model.StartTime.ToString(@"hh\:mm")</dd>

            <dt>Typ av dyk:</dt>
            <dd>@Model.DivePurpose?.Name</dd>

            <dt>Dykledare:</dt>
            <dd>
                @if (leader != null)
                {
                    <span>@leader.Person.Signature - @leader.Person.Name</span>
                }
                else
                {
                    <span>Ingen dykledare registrerad</span>
                }
            </dd>

            
            @if (support != null)
            {
                <dt>Dykskötare:</dt>
                <dd>@support.Person.Signature - @support.Person.Name</dd>
            }
            
            <dt>Anteckningar:</dt>
            <dd>@Model.Notes</dd>

        </dl>

        <!-- Höger kolumn: karta -->
        <div id="details-map"></div>

    </div>

    <!-- Dykare -->
    <h4>Dykare</h4>

    <div class="details-divers">

        @foreach (var d in divers ?? new List<divelog.Models.DiveParticipant>())
        {
            <div class="diver-detail-card">

                <h5>
                    <span>@d.Person.Signature - @d.Person.Name</span>
                </h5>
                <dl class="details-list">
                    <dt>Djup:</dt>
                    <dd>@(d.Depth?.ToString() ?? "-") m</dd>

                    <dt>Dyktid:</dt>
                    <dd>@(d.DiveTime?.ToString() ?? "-") min</dd>

                    <dt>Expositionstid:</dt>
                    <dd>@(d.ExposureTime?.ToString() ?? "-") min</dd>

                    <dt>Kvävebelastning:</dt>
                    <dd>@(d.NitrogenLoad?.ToString() ?? "-")</dd>

                    @if (d.AirPressureBefore.HasValue && d.AirPressureAfter.HasValue)
                    {
                        <dt>Luft:</dt>
                        <dd>@($"{d.AirPressureBefore} / {d.AirPressureAfter} bar")</dd>
                    }
                    else
                    {
                        <span></span>
                    }
                </dl>
            </div>
        }

    </div>

    <!-- Knappar -->
    <div class="details-button-wrapper">

        <a asp-action="Edit" asp-route-id="@Model.Id" class="form-btn">
            Redigera
        </a>

        <a asp-action="Delete" asp-route-id="@Model.Id" class="form-btn remove-btn">
            Ta bort
        </a>

    </div>

</div>

<div class="navigate-back">
    <a asp-action="Index">Tillbaka till Dyklogg</a>
</div>

@section Scripts {
    <script>

        //Byter ut punkter i mina sparade koordinater till decimaler
        var lat = @Model?.Latitude.ToString(System.Globalization.CultureInfo.InvariantCulture);
        var lng = @Model?.Longitude.ToString(System.Globalization.CultureInfo.InvariantCulture);

        //Skapa karta
        var map = L.map('details-map').setView([lat, lng], 14);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '&copy; OpenStreetMap'
        }).addTo(map);

        //Lägger till markör
        L.marker([lat, lng]).addTo(map);

    </script>
}