@model divelog.Models.Person

@{
    ViewData["Title"] = "Detaljer";
}

<h1>Detaljer</h1>

<div>
    <h3 class="person-title">
        @Model.Signature - @Model.Name
    </h3>

    <div class="person-content">

        <dl class="person-details">

            <dt>Grupp</dt>
            <dd>@Html.DisplayFor(model => model.Group.Name)</dd>

            <dt>Roller</dt>
            <dd>
                @if (Model.PersonRoles != null && Model.PersonRoles.Any())
                {
                    <ul class="role-list">
                        @foreach (var personRole in Model.PersonRoles)
                        {
                            <li>@personRole.DiveRole.Name</li>
                        }
                    </ul>
                }
                else
                {
                    <span>Inga roller tilldelade</span>
                }
            </dd>

            @if (Model.PersonRoles?.Any(pr => pr.DiveRole?.Name == "Dykare") == true)
            {
                <dt>Började dyka</dt>
                <dd>@Model.StartedDiving?.ToString("yyyy-MM-dd")</dd>
            }

        </dl>
    </div>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Redigera</a> |
    <a asp-action="Index">Tillbaka till Personal</a>
</div>
