@model divelog.ViewModels.PersonEditViewModel

@{
    ViewData["Title"] = "Redigera";
}

<h1>Redigera</h1>

<h4>Person</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div asp-validation-summary="All" class="text-danger"></div>

            <input type="hidden" asp-for="Id" />

            <div class="form-group">
                <label asp-for="Signature" class="control-label">Signatur:</label>
                <input asp-for="Signature" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="Name" class="control-label">Namn:</label>
                <input asp-for="Name" class="form-control" />
            </div>
            <div class="form-group">
                <label asp-for="GroupId" class="control-label">Grupp:</label>
                <select asp-for="GroupId" class="form-control" asp-items="ViewBag.GroupId"></select>
            </div>
            <div class="form-group">
                <label>Roller:</label>
                @for (int i = 0; i < Model.AvailableRoles.Count; i++)
                {
                    <div class="form-check">
                        <input class="form-check-input role-checkbox" type="checkbox" name="SelectedRoleIds"
                               value="@Model.AvailableRoles[i].Id" id="role_@i" data-role-name="@Model.AvailableRoles[i].Name"
                        @(Model.SelectedRoleIds.Contains(Model.AvailableRoles[i].Id) ? "checked" : "") />
                        <label class="form-check-label" for="role_@i">
                            @Model.AvailableRoles[i].Name
                        </label>
                    </div>
                }
            </div>
            <div class="form-group" id="startedDivingField" style="display:none;">
                <label asp-for="StartedDiving" class="control-label">Började dyka:</label>
                <input asp-for="StartedDiving" type="date" class="form-control" />
            </div>
            <div class="form-group">
                <input type="submit" value="Spara" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Tillbaka till Personal</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        //Funktion som visar eller döljer fältet för StartedDiving
        function toggleStartedDiving() {
            let show = false;

            //Kontrollerar om checkboxen för dykare är ifylld, om checkboxen är ifylld ska datumfältet visas
            document.querySelectorAll(".role-checkbox").forEach(cb => {
                if (cb.checked && cb.dataset.roleName === "Dykare") {
                    show = true;
                }
            });

            document.getElementById("startedDivingField").style.display =
                show ? "block" : "none";
        }

        document.querySelectorAll(".role-checkbox").forEach(cb => {
            cb.addEventListener("change", toggleStartedDiving);
        });

        //Kör direkt när sidan laddas
        toggleStartedDiving();
    </script>
}
