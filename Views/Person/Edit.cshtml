@model divelog.ViewModels.PersonEditViewModel

@{
    ViewData["Title"] = "Redigera";
}

<h1>Redigera</h1>

<div>
    <div>
        <form asp-action="Edit" class="person-form">
            <h2>Person</h2>
            <!-- Felmeddelanden -->
            <div asp-validation-summary="All" class="error"></div>
            <input type="hidden" asp-for="Id" />
            <div class="form-row">
                <label asp-for="Signature">Signatur:</label>
                <input asp-for="Signature" />
            </div>
            <div class="form-row">
                <label asp-for="Name">Namn:</label>
                <input asp-for="Name" />
            </div>
            <div class="form-row">
                <label asp-for="GroupId">Grupp:</label>
                <select asp-for="GroupId" asp-items="ViewBag.GroupId"></select>
            </div>
            <div class="form-row">
                <label>Roller:</label>
                <div class="checkbox-column">
                    @for (int i = 0; i < Model.AvailableRoles.Count; i++)
                    {
                        <div class="checkbox-row">
                            <input class="role-checkbox" type="checkbox" name="SelectedRoleIds"
                                   value="@Model.AvailableRoles[i].Id" id="role_@i"
                                   data-role-name="@Model.AvailableRoles[i].Name"
                            @(Model.SelectedRoleIds.Contains(Model.AvailableRoles[i].Id) ? "checked" : "") />
                            <label for="role_@i">
                                @Model.AvailableRoles[i].Name
                            </label>
                        </div>
                    }
                </div>
            </div>
            <div class="form-row" id="startedDivingField" style="display:none;">
                <label asp-for="StartedDiving">Började dyka:</label>
                <input asp-for="StartedDiving" type="date" />
            </div>
            <div class="btn-container">
                <input type="submit" value="Spara" class="submit-btn" />
            </div>
        </form>
    </div>
</div>

<div class="navigate-back">
    <a asp-action="Index">Tillbaka till Personal</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }

    <script>
        //Funktion som visar eller döljer fältet för StartedDiving
        function toggleStartedDiving() {
            let show = false;

            //Kontrollerar om checkboxen för dykare är ifylld, om checkboxen är ifylld ska datumfältet visas
            document.querySelectorAll(".role-checkbox").forEach(cb => {
                if (cb.checked && cb.dataset.roleName === "Dykare") {
                    show = true;
                }
            });

            document.getElementById("startedDivingField").style.display =
                show ? "flex" : "none";
        }

        document.querySelectorAll(".role-checkbox").forEach(cb => {
            cb.addEventListener("change", toggleStartedDiving);
        });

        //Kör direkt när sidan laddas
        toggleStartedDiving();
    </script>
}
